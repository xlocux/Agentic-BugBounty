# HackerOne API credentials — required for h1:sync, h1:disclosed, h1:bootstrap
H1_API_USERNAME=your_h1_username
H1_API_TOKEN=your_h1_api_token

# OpenRouter API key — required for:
#   - LLM fallback chain in calibration:extract-skills and cve:sync (free models)
#   - Dual researcher second pass (GPT-4.5)
# Free tier supports: Llama 4 Scout, Qwen3 4B, Gemini 2.5 Flash (all free)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
