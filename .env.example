# HackerOne API credentials — required for h1:sync, h1:disclosed, h1:bootstrap
H1_API_USERNAME=your_h1_username
H1_API_TOKEN=your_h1_api_token

# OpenRouter API keys — required for:
#   - LLM fallback chain in calibration:extract-skills and cve:sync (free models)
#   - Dual researcher second pass (free models)
#
# Key rotation: set up to 5 keys. All non-empty keys are pooled and rotated
# automatically on 401/429/busy errors to avoid per-key rate limits.
# You only need OPENROUTER_API_KEY for single-key use.
#
# Get keys at: https://openrouter.ai/keys
# Rate limits: https://openrouter.ai/docs/api/reference/limits
OPENROUTER_API_KEY=your_key_1_here
OPENROUTER_API_KEY_1=your_key_1_here
OPENROUTER_API_KEY_2=your_key_2_here
OPENROUTER_API_KEY_3=your_key_3_here
OPENROUTER_API_KEY_4=your_key_4_here
OPENROUTER_API_KEY_5=your_key_5_here

# Model config: see config/openrouter.json for the full free model list
# and to set the preferred researcher model.

# ── Custom tool paths (auto-populated by setup-tools.js) ─────────────────────
BROJACK_BIN=
SEX_PATTERNS_PATH=
