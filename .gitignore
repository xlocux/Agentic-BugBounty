# ── Git worktrees ────────────────────────────────────────────────────────────
.worktrees/

# ── Cloned / downloaded target source code ──────────────────────────────────
# Never commit scanned project sources — clone them locally via target setup
targets/*/src/

# ── Findings and reports ─────────────────────────────────────────────────────
# Contains potentially sensitive vulnerability details; keep local
targets/*/findings/
targets/*/logs/

# ── Intelligence databases and snapshots ─────────────────────────────────────
# SQLite databases (binary, large, regenerated by sync scripts)
targets/*


# Global disclosed dataset (large, regenerated)
data/global-intelligence/

# ── Environment and credentials ───────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
credentials.json

# ── OS and editor artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnp.*
.yarn/cache/
.yarn/unplugged/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
.claude\settings.json
docs/superpowers/*
