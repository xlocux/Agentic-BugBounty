{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitIntelligence",
  "type": "object",
  "required": ["schema_version", "generated_at", "target", "security_commits", "bypass_vectors", "secrets_found", "version_delta"],
  "properties": {
    "schema_version":   { "type": "integer", "const": 2 },
    "generated_at":     { "type": "string" },
    "target":           { "type": "string" },
    "security_commits": { "type": "array" },
    "bypass_vectors":   { "type": "array" },
    "secrets_found":    { "type": "array" },
    "version_delta":    { "type": "array" }
  }
}
