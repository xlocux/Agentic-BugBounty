{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session Response",
  "type": "object",
  "required": ["schema_version", "request_id", "written_at", "written_by", "status"],
  "properties": {
    "schema_version":  { "type": "string" },
    "request_id":      { "type": "integer", "minimum": 0 },
    "written_at":      { "type": "string" },
    "written_by":      { "type": "string", "enum": ["ui"] },
    "status":          { "type": "string" },
    "selected_assets": { "type": "array", "items": { "type": "string" } },
    "approved_ops":    { "type": "array", "items": { "type": "string" } },
    "skip_op":         { "type": "string" }
  },
  "additionalProperties": true
}
