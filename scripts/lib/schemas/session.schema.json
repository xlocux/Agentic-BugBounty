{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session State",
  "type": "object",
  "required": ["schema_version", "request_id", "written_at", "written_by", "status"],
  "properties": {
    "schema_version": { "type": "string" },
    "request_id":     { "type": "integer", "minimum": 0 },
    "written_at":     { "type": "string" },
    "written_by":     { "type": "string", "enum": ["pipeline"] },
    "status": {
      "type": "string",
      "enum": ["awaiting_assets", "awaiting_approval", "running", "done", "error"]
    },
    "phase":          { "type": "string" },
    "asset_type":     { "type": "string" },
    "available_assets": { "type": "array" },
    "plan":           { "type": "array" },
    "context":        {},
    "current_op":     { "type": "string" },
    "completed_ops":  { "type": "array" },
    "findings_so_far": { "type": "integer" },
    "findings":       { "type": "array" }
  },
  "additionalProperties": true
}
